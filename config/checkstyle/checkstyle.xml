<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Juml CheckStyle設定
    基本的なコード品質チェック。厳格すぎず、実用的な範囲で。
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>

    <!-- ファイルレベルのチェック -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="false"/>
        <!-- SPDEditor uses tabs intentionally for indentation -->
        <property name="severity" value="ignore"/>
    </module>

    <module name="SuppressionFilter">
        <property name="file" value="${config_loc}/suppressions.xml"/>
    </module>

    <!-- 全ソースに 2 行の SPDX ライセンスヘッダを付与しているため、ヘッダ 2 行分を加味する。
         VS Code 風パリティ機能 (タブ DnD/MRU/パンくず・アクティビティバー・ミニマップ) の
         追加に伴い、主要 UI クラス (DiagramTabPane / UmlMainFrame / SvgPreviewPanel) の
         配線行を収められるよう上限を 902 (= 900 + ヘッダ 2 行) へ引き上げる。機能ロジック
         自体は専用クラスへ分離し、肥大化はこの上限で引き続き抑制する。 -->
    <module name="FileLength">
        <property name="max" value="902"/>
    </module>

    <module name="TreeWalker">
        <!-- インポートチェック -->
        <module name="AvoidStarImport">
            <property name="excludes" value="java.awt,java.awt.event,javax.swing,juml.core.models,juml.core.view,java.io,java.util,org.junit.Assert"/>
        </module>
        <module name="RedundantImport"/>
        <module name="UnusedImports"/>

        <!-- 命名規則 -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$|^[a-z][a-zA-Z0-9]*$"/>
        </module>
        <module name="LocalVariableName"/>
        <module name="MethodName">
            <property name="format" value="^[a-zA-Z][a-zA-Z0-9]*$"/>
        </module>
        <module name="PackageName"/>
        <module name="TypeName"/>

        <!-- コードの問題 -->
        <module name="EmptyStatement"/>
        <module name="EqualsHashCode"/>
        <module name="MissingSwitchDefault"/>
        <module name="SimplifyBooleanExpression"/>
        <module name="SimplifyBooleanReturn"/>

        <!-- メソッドの長さ -->
        <module name="MethodLength">
            <property name="max" value="150"/>
        </module>

        <!-- パラメータ数 -->
        <module name="ParameterNumber">
            <property name="max" value="8"/>
        </module>

        <!-- 修飾子の順序 -->
        <module name="ModifierOrder"/>

        <!-- 不要なブロック -->
        <module name="EmptyBlock">
            <property name="option" value="TEXT"/>
            <property name="tokens" value="LITERAL_TRY,LITERAL_FINALLY,LITERAL_IF,LITERAL_ELSE"/>
        </module>

        <!-- ArrayTypeStyle -->
        <module name="ArrayTypeStyle"/>
    </module>
</module>
